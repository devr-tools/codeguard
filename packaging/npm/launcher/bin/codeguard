#!/usr/bin/env node
"use strict";

// Launcher for @devr-tools/codeguard.
//
// The real binary ships inside a platform-specific optionalDependency
// (e.g. @devr-tools/codeguard-darwin-arm64). npm installs only the package that
// matches the host's os/cpu, so this shim resolves that package and execs the
// bundled binary. There is deliberately no postinstall step and no network
// access at install time.

const { spawnSync } = require("child_process");
const os = require("os");

const PLATFORM_PACKAGES = {
  "darwin-x64": "@devr-tools/codeguard-darwin-x64",
  "darwin-arm64": "@devr-tools/codeguard-darwin-arm64",
  "linux-x64": "@devr-tools/codeguard-linux-x64",
  "linux-arm64": "@devr-tools/codeguard-linux-arm64",
};

function resolveBinary() {
  const key = `${os.platform()}-${os.arch()}`;
  const pkg = PLATFORM_PACKAGES[key];
  if (!pkg) {
    throw new Error(
      `codeguard: unsupported platform "${key}". ` +
        `Supported: ${Object.keys(PLATFORM_PACKAGES).join(", ")}.`
    );
  }
  try {
    return require.resolve(`${pkg}/bin/codeguard`);
  } catch (_err) {
    throw new Error(
      `codeguard: the platform package "${pkg}" is not installed.\n` +
        `This usually means codeguard was installed with --no-optional/--omit=optional, ` +
        `or on an unsupported platform. Reinstall without those flags.`
    );
  }
}

const result = spawnSync(resolveBinary(), process.argv.slice(2), {
  stdio: "inherit",
});

if (result.error) {
  throw result.error;
}
process.exit(result.status === null ? 1 : result.status);
