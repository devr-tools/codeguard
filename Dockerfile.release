# Digest-pinned for build-input integrity (OWASP A08); tag comment is
# human-readable and Dependabot bumps the digest.
FROM alpine:3.24@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b

RUN apk --no-cache add ca-certificates \
    && addgroup -S codeguard && adduser -S -G codeguard -H codeguard

COPY codeguard /usr/bin/codeguard

# Run as an unprivileged user; codeguard only needs to read the mounted repo.
USER codeguard

ENTRYPOINT ["/usr/bin/codeguard"]
